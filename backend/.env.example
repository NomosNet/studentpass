MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_PASSWORD=devpassword
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACC_TOKEN_EXP_MIN=60
# Через запятую, для VPS: http://161.104.33.28 или https://yourdomain.ru
CORS_ORIGINS=

# SMTP (если не задан SMTP_HOST — код регистрации пишется в лог API)
# Yandex: smtp.yandex.ru, порт 465, SMTP_USE_SSL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_SSL=false
